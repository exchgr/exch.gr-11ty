<article>
  {% render 'articleHeader', article: article %}
  {% if article.og_image %}
    <p>
      <img src="{{ article.og_image.url }}">
    </p>
    {{ article.body | markdown | minimalHtmlClip: clip }}
  {% else %}
    {{ article.body | markdown | clip: clip }}
  {% endif %}
  {% render 'articleFooter', article: article %}
</article>
